# ─────────────────────────────────────────────────────────────────────────
# Stationly Admin Console — environment
# Copy to `.env.local` and fill in. NEVER commit `.env.local`.
# ─────────────────────────────────────────────────────────────────────────

# Which environment THIS deployment targets. The console auto-routes to it —
# there is NO env switcher in the UI. A staging deployment talks only to
# staging and shows a "⚠ STAGING ENVIRONMENT" banner; prod talks only to prod
# and shows no banner; local shows a "LOCAL DEV" banner.
#   local | staging | production
STATIONLY_ENV=local

# ── App login gate (defence-in-depth on top of Cloudflare Access) ──────────
# Shared password to enter the console, and a random secret used to sign the
# session cookie. Generate SESSION_SECRET with:  openssl rand -hex 32
ADMIN_PASSWORD=
SESSION_SECRET=

# ── Target backend (only the one matching STATIONLY_ENV is used) ───────────
# Base URLs default to the same hosts StationlyUI's AppConfig.kt uses; override
# only if needed.
#   LOCAL   -> http://localhost:3000
#   STAGING -> https://staging-api.stationly.co.uk
#   PROD    -> https://api.stationly.co.uk

# --- local ---
# LOCAL_BACKEND_URL=http://localhost:3000
LOCAL_ADMIN_KEY=

# --- staging ---
# STAGING_BACKEND_URL=https://staging-api.stationly.co.uk
STAGING_ADMIN_KEY=
STAGING_CF_ACCESS_CLIENT_ID=
STAGING_CF_ACCESS_CLIENT_SECRET=

# --- production ---
# PROD_BACKEND_URL=https://api.stationly.co.uk
PROD_ADMIN_KEY=
PROD_CF_ACCESS_CLIENT_ID=
PROD_CF_ACCESS_CLIENT_SECRET=
